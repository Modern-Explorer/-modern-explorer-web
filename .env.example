# ── Analytics & SEO ──────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (get from analytics.google.com)
# Format: G-XXXXXXXXXX
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console verification code (get from search.google.com/search-console)
# Paste the content value from the <meta name="google-site-verification"> tag
VITE_GSC_VERIFICATION=

# ── Claude API key — required for MESA AI chat
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Gmail SMTP credentials
# Use a Gmail App Password (not your regular password).
# To create one: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: override the default port (3001)
# PORT=3001
